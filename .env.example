# ══════════════════════════════════════════════════════
#  AI Interview Simulator — Environment Variables
#  Copy this file to .env and fill in your real values.
# ══════════════════════════════════════════════════════

# ── Django core ───────────────────────────────────────
SECRET_KEY=django-insecure-replace-me-with-50-random-chars
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ──────────────────────────────────────────
# Leave blank to use SQLite (local dev).
# Set a PostgreSQL URL for production:
#   postgresql://user:password@host:5432/dbname
DATABASE_URL=

# ── OpenAI ────────────────────────────────────────────
# Required for AI question generation & answer evaluation.
# Without it the app falls back to a static question bank + heuristic scoring.
# Get your key: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# ── Anthropic (Claude) ────────────────────────────────
# Required for AI resume screening.
# Get your key: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# ── Redis (Django Channels) ───────────────────────────
# Required for WebSocket support.
# Local:  redis://localhost:6379
# Docker: docker run -d -p 6379:6379 redis:7
# Leave blank to use the in-memory channel layer (single-process only).
REDIS_URL=redis://localhost:6379

# ── CORS ──────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
