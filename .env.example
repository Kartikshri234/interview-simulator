# ── AI Interview Simulator — Environment Variables ──────────
# Copy this file to .env and fill in your values.

# Django
SECRET_KEY=django-insecure-replace-me-with-50-random-chars
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# OpenAI  →  https://platform.openai.com/api-keys
# Required for AI question generation & answer evaluation.
# Without it the app uses built-in static questions + heuristic scoring.
OPENAI_API_KEY=sk-your-openai-api-key-here

# Redis (for Django Channels WebSocket support)
# Run locally:  redis-server
# Or Docker:    docker run -d -p 6379:6379 redis:7
REDIS_URL=redis://localhost:6379
